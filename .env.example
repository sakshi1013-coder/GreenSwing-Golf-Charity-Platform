# ===================================
# GreenSwing Environment Variables
# Copy this to .env and fill in values
# ===================================

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# JWT Secret (change in production!)
JWT_SECRET=greenswing_super_secret_jwt_key_change_me_2026

# ===================================
# Supabase (https://supabase.com)
# ===================================
# 1. Create a project at supabase.com
# 2. Run database/schema.sql in SQL Editor
# 3. Run database/functions.sql in SQL Editor
# 4. Copy URL and keys from Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...your_anon_key
SUPABASE_SERVICE_KEY=eyJhbGci...your_service_key

# ===================================
# Stripe (https://stripe.com)
# ===================================
# 1. Create account at stripe.com
# 2. Get API keys from Developers → API keys
# 3. Create products/prices in Product catalog:
#    - Monthly: £9.99/month recurring
#    - Yearly: £89.99/year recurring
# 4. Copy secret key and price IDs below
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (from Product catalog)
STRIPE_MONTHLY_PRICE_ID=price_monthly_id
STRIPE_YEARLY_PRICE_ID=price_yearly_id

# ===================================
# Supabase Storage (for winner proofs)
# ===================================
# Set up in Supabase Dashboard → Storage:
# 1. Create bucket: winner-proofs (private)
# 2. Policy: authenticated users can upload to proofs/{uid}/*
# 3. Policy: admin users can read all
# 4. Max size: 5MB
# 5. Accepted types: image/jpeg, image/png, application/pdf
